<view class="page">
  <view class="hero">
    <view class="eyebrow">Device Setup</view>
    <view class="title">网络配置</view>
    <view class="subtle">ESP32 只保存 WiFi 和后端 URL，AI Key 留在香橙派。</view>
  </view>

  <view class="panel">
    <view class="field">
      <view class="field-label">WiFi 名称</view>
      <input class="input" value="{{wifiSsid}}" bindinput="onInput" data-key="wifiSsid" placeholder="Xiaomi_F165" />
    </view>
    <view class="field">
      <view class="field-label">WiFi 密码</view>
      <input class="input" value="{{wifiPassword}}" bindinput="onInput" data-key="wifiPassword" password placeholder="不会写入仓库" />
    </view>
    <view class="field">
      <view class="field-label">后端 URL</view>
      <input class="input mono" value="{{baseUrl}}" bindinput="onInput" data-key="baseUrl" placeholder="http://192.168.31.58:8787" />
    </view>
    <view class="actions">
      <button class="btn secondary" bindtap="saveLocal">保存本机</button>
      <button class="btn primary" bindtap="sendToDevice">发送设备</button>
    </view>
  </view>
</view>
